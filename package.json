		"jest-expo": "^54.0.16",
		"lint-staged": "^16.2.7",
		"prettier": "^3.7.4",
		"prettier-plugin-sort-json": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.5.14",
		"tailwindcss": "^3.4.17",
		"ts-node": "^10.9.2",
		"typescript": "~5.9.2"
	},
	"private": true
}
