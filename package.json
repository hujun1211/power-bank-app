{
	"name": "change-bank",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"start": "expo start",
		"reset-project": "node ./scripts/reset-project.js",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"web": "expo start --web",
		"lint": "expo lint",
		"gen:license": "license-report --output=json --only=prod > ./assets/licenses.json",
		"bump:version": "node ./scripts/bump-version.js",
		"pre-release": "npm run gen:license && npm run bump:version",
		"prebuild": "expo prebuild",
		"release:android:apk": "cd android && ./gradlew assembleRelease",
		"release:android:aab": "cd android && ./gradlew bundleRelease",
		"test": "jest --watchAll",
		"prepare": "husky",
		"format": "prettier --write ."
	},
	"jest": {
		"preset": "react-native",
		"setupFiles": [
			"./jestSetup.js"
		]
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,vue,json,css,scss,md}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@expo/react-native-action-sheet": "^4.1.1",
		"@expo/vector-icons": "^15.0.3",
		"@react-native-async-storage/async-storage": "^2.2.0",
		"@react-navigation/bottom-tabs": "^7.4.0",
		"@react-navigation/elements": "^2.6.3",
		"@react-navigation/native": "^7.1.8",
		"@shopify/flash-list": "2.0.2",
		"expo": "~54.0.25",
		"expo-blur": "^15.0.7",
		"expo-constants": "~18.0.10",
		"expo-font": "~14.0.9",
		"expo-haptics": "~15.0.7",
		"expo-image": "~3.0.10",
		"expo-linear-gradient": "^15.0.7",
		"expo-linking": "~8.0.9",
		"expo-localization": "~17.0.8",
		"expo-notifications": "^0.32.14",
		"expo-router": "~6.0.15",
		"expo-splash-screen": "~31.0.11",
		"expo-status-bar": "~3.0.8",
		"expo-symbols": "~1.0.7",
		"expo-system-ui": "~6.0.8",
		"expo-web-browser": "~15.0.9",
		"i18next": "^25.7.2",
		"lucide-react-native": "^0.555.0",
		"nanoid": "^4.0.2",
		"nativewind": "^4.2.1",
		"react": "^19.2.3",
