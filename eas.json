{
	"build": {
		"production-aab": {
			"distribution": "store",
			"android": {
				"buildType": "app-bundle",
				"gradleCommand": ":app:bundleRelease"
			},
			"env": {
				"GRADLE_BUILD_PROPERTY_org_gradle_jvmargs": "-Xmx4g"
			}
		},
		"production-apk": {
			"distribution": "store",
			"android": {
				"buildType": "apk"
			}
		},
		"preview": {
			"android": {
				"buildType": "apk"
			}
		},
		"production-ios": {
			"distribution": "store",
			"ios": {}
		}
	},
	"cli": {
		"version": ">= 5.0.0",
		"appVersionSource": "local",
		"promptToConfigurePushNotifications": false
	}
}
